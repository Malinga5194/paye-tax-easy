# Entity Framework migrations (keep Migrations folder but ignore snapshots if desired)
# Uncomment if you want to ignore migration snapshots:
# **/Migrations/*Snapshot.cs

# Secrets / config overrides (never commit real secrets)
# appsettings.Development.json is committed — it only has localhost/dev config
appsettings.Production.json
appsettings.Staging.json
secrets.json
*.pfx
*.p12

## ── Node / React ──────────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# Keep .env files (they only contain localhost URLs, no secrets)
# .env files are committed so the lecturer can run the project immediately
# .env.example files are always committed

# npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# TypeScript
*.tsbuildinfo

